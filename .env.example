# AetherSwap Docker 环境变量示例
# 复制为 .env 后按需修改: cp .env.example .env

# 运行模式（Docker 中固定为 server）
AETHERSWAP_MODE=server

# 非交互启动时自动确认免责声明（Docker 必需）
AETHERSWAP_AGREE_DISCLAIMER=1

# 宿主机访问端口（容器内监听端口固定为 28472）
AETHERSWAP_HOST_PORT=28472

# 可选：代理（访问 Steam 社区时使用）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# 可选：强制无头 / 手动登录
# AETHERSWAP_HEADLESS=1
# AETHERSWAP_MANUAL_LOGIN_ONLY=1
